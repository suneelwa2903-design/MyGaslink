# .env.monitor — ADLC Framework
# Infrastructure monitoring config. Gitignored — never commit this file.
# Copy to each project and fill in values.

# ─── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
PROJECT_NAME=project-name-here

# ─── API ─────────────────────────────────────────────────────────────
# Leave blank if not applicable
SERVICE_URL=https://your-api-domain.com

# ─── Database ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
# DB_NAME and DB_USER not needed for health check (pg_isready only checks connectivity)

# ─── Redis ───────────────────────────────────────────────────────────
# Leave blank if not using Redis
REDIS_HOST=
REDIS_PORT=6379

# ─── Thresholds ──────────────────────────────────────────────────────
DISK_THRESHOLD=80
DISK_CRITICAL=90
MEM_THRESHOLD=90

# ─── Process Monitor (optional) ──────────────────────────────────────
# Name of a process that must always be running (e.g., celery, gunicorn)
REQUIRED_PROCESS=

# ─── Cron Alert Config ───────────────────────────────────────────────
# Set to "true" to get Telegram alert on successful cron runs too
ALERT_ON_SUCCESS=false
