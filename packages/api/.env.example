# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://gaslink:gaslink_dev@localhost:5432/gaslink?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173,http://localhost:8081"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@mygaslink.com"
CONTACT_FORM_EMAIL="info@mygaslink.com"

# ─── GST / WhiteBooks (GasLink-level credentials for SaaS billing) ────────────
GASLINK_GST_CLIENT_ID=""
GASLINK_GST_CLIENT_SECRET=""
GASLINK_GST_USERNAME=""
GASLINK_GST_GSTIN=""
GASLINK_GST_SANDBOX=true

# ─── AWS (Production) ─────────────────────────────────────────────────────────
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""

# ─── WhatsApp Business (Future) ───────────────────────────────────────────────
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
