# ═══════════════════════════════════════════════════════════════════════════════
# packages/api — backend service env vars
#
# Every var below MUST appear here, even if commented out. Audit:
#   $ grep -rEn 'process\\.env\\.' packages/api/src
# Defaults are wired in packages/api/src/config/index.ts; production deploys
# go through validateEnv() which hard-fails on missing JWT/DB/CORS.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────────
# Local docker dev DB exposes 5433 → 5432. Use 5432 in CI / prod.
DATABASE_URL="postgresql://gaslink:gaslink_dev@localhost:5433/gaslink?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# 32+ chars in production. validateEnv() rejects the dev defaults in prod.
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173,http://localhost:8081"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@mygaslink.com"
CONTACT_FORM_EMAIL="info@mygaslink.com"

# ─── GST / WhiteBooks (GasLink-level credentials for SaaS billing) ────────────
GASLINK_GST_CLIENT_ID=""
GASLINK_GST_CLIENT_SECRET=""
GASLINK_GST_USERNAME=""
GASLINK_GST_GSTIN=""
GASLINK_GST_SANDBOX=true

# ─── Group A: Layer 1 WhiteBooks credentials (env-var routing, scope × env) ──
# These are GasLink-global Layer 1 credentials (client_id + client_secret),
# shared by all distributors in the matching mode. Per-scope (einvoice +
# ewaybill) × per-environment (sandbox + prod) = 8 vars total.
#
# Layer 2 (username/password/email/gstin) lives per-distributor in the
# gst_credentials table — NOT here.
#
# Sandbox values are required for any dev/test work against dist-demo.
# Prod values are required to set any tenant to gst_mode='live' — the code
# throws NO_PROD_CREDS without them.
#
# Legacy fallback: if sandbox env vars are empty AND a dist has gst_credentials
# rows with non-null client_id/client_secret, the code falls back to DB for
# backward compat. Live mode never falls back.
WHITEBOOKS_EINVOICE_SANDBOX_CLIENT_ID=
WHITEBOOKS_EINVOICE_SANDBOX_CLIENT_SECRET=
WHITEBOOKS_EINVOICE_SANDBOX_EMAIL=
WHITEBOOKS_EWAYBILL_SANDBOX_CLIENT_ID=
WHITEBOOKS_EWAYBILL_SANDBOX_CLIENT_SECRET=
WHITEBOOKS_EWAYBILL_SANDBOX_EMAIL=
WHITEBOOKS_EINVOICE_PROD_CLIENT_ID=
WHITEBOOKS_EINVOICE_PROD_CLIENT_SECRET=
WHITEBOOKS_EINVOICE_PROD_EMAIL=
WHITEBOOKS_EWAYBILL_PROD_CLIENT_ID=
WHITEBOOKS_EWAYBILL_PROD_CLIENT_SECRET=
WHITEBOOKS_EWAYBILL_PROD_EMAIL=

# ─── Seed-only legacy WhiteBooks vars (used by prisma/seed.ts for dist-002) ──
# These pre-date Group A. The seed script populates dist-002's gst_credentials
# row from these so integration tests have a known-shape credential set.
# Real credentials should NOT live here in prod — use the Layer 1 vars above.
WHITEBOOKS_EINVOICE_CLIENT_ID=your_einvoice_client_id_here
WHITEBOOKS_EINVOICE_CLIENT_SECRET=your_einvoice_client_secret_here
WHITEBOOKS_EINVOICE_USERNAME=your_einvoice_username_here
WHITEBOOKS_EINVOICE_PASSWORD=your_einvoice_password_here
WHITEBOOKS_EWAYBILL_CLIENT_ID=your_ewaybill_client_id_here
WHITEBOOKS_EWAYBILL_CLIENT_SECRET=your_ewaybill_client_secret_here
WHITEBOOKS_EWAYBILL_USERNAME=your_ewaybill_username_here
WHITEBOOKS_EWAYBILL_PASSWORD=your_ewaybill_password_here

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# Read in packages/api/src/lib/sentry.ts. If unset, Sentry is a no-op.
SENTRY_DSN=""

# ─── AWS (Production) ─────────────────────────────────────────────────────────
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""

# ─── WhatsApp Business (Future) ───────────────────────────────────────────────
# Reserved — no current code path reads these. Will be wired up post-launch.
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
