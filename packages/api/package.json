    "@sentry/node": "^10.45.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.0",
    "multer": "^2.0.0",
    "node-cron": "^4.2.0",
    "nodemailer": "^7.0.0",
    "pdfkit": "^0.17.0",
    "qrcode": "^1.5.0",
    "sharp": "^0.34.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
