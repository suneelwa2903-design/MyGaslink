    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfkit": "^0.13.0",
    "@types/qrcode": "^1.5.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.19.2",
