  distributor Distributor @relation(fields: [distributorId], references: [id])

  @@unique([distributorId, settingKey])
  @@map("distributor_settings")
}

// ─── Tally Setup (per-tenant accounting export config) ──────────────────────
//
// Drives the Tally XML export on the Reports page. One row per distributor.
// All ledger/voucher fields have sane defaults so a distributor whose Tally
// uses the stock Chart of Accounts never has to touch this — the export
// works out of the box. The `cylinderStockItems` JSON is a map of
// CylinderType.id → Tally stock item name (so a 14.2 KG cylinder typed in
// MyGasLink can be mapped to "Indane 14.2 KG Domestic Cylinder" or whatever
// the distributor created in Tally). Missing keys fall back to
// invoiceItem.description at export time — that covers both
// "not-mapped-yet" cylinder lines AND legitimate non-cylinder lines
// (transport charges, ad-hoc fees) whose InvoiceItem.cylinderTypeId is null.
model TallySettings {
  id            String @id @default(uuid()) @map("tally_settings_id")
  distributorId String @unique @map("distributor_id")

  // Tally version — drives a handful of XML-element differences between
  // Prime and ERP 9. Constrained to "prime" | "erp9" at the route layer.
  tallyVersion     String  @default("prime") @map("tally_version")
  // Optional override for SVCURRENTCOMPANY. NULL → fall back to
  // Distributor.legalName at export time so the XML always identifies
  // a company even before this row is configured.
  tallyCompanyName String? @map("tally_company_name")

  // Ledger names — must match the Tally Chart of Accounts exactly.
  ledgerSales         String @default("Sales")           @map("ledger_sales")
  ledgerCgst          String @default("Output CGST")     @map("ledger_cgst")
  ledgerSgst          String @default("Output SGST")     @map("ledger_sgst")
  ledgerIgst          String @default("Output IGST")     @map("ledger_igst")
  ledgerCash          String @default("Cash")            @map("ledger_cash")
  ledgerBank          String @default("Bank Account")    @map("ledger_bank")
  ledgerSundryDebtors String @default("Sundry Debtors")  @map("ledger_sundry_debtors")
  ledgerRoundOff      String @default("Round Off")       @map("ledger_round_off")

  // Voucher type names — must match Tally's Voucher Types screen.
  voucherTypeSales      String @default("Sales")       @map("voucher_type_sales")
  voucherTypeReceipt    String @default("Receipt")     @map("voucher_type_receipt")
  voucherTypeCreditNote String @default("Credit Note") @map("voucher_type_credit_note")
  voucherTypeDebitNote  String @default("Debit Note")  @map("voucher_type_debit_note")

  // Inventory — Tally's Unit of Measure (UOM) for cylinder stock lines.
  // Tally's stock default is "Nos"; we capitalise to "NOS" to align with
  // the GSTR-1 UQC convention (InvoiceItem.uom defaults to "NOS" too —
  // see invoiceService.createInvoiceFromOrder).
  stockUnit String @default("NOS") @map("stock_unit")

  // Map of CylinderType.id → Tally stock item name. Validation at write
  // time ensures every key is a CylinderType owned by this distributor
  // (cross-tenant leak guard — anti-pattern #13).
  cylinderStockItems Json @default("{}") @map("cylinder_stock_items")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  distributor Distributor @relation(fields: [distributorId], references: [id])

  @@map("tally_settings")
}

// ─── Licenses ────────────────────────────────────────────────────────────────

model License {
  id            String      @id @default(uuid()) @map("license_id")
  distributorId String      @map("distributor_id")
  licenseType   LicenseType @map("license_type")
  licenseName   String      @map("license_name")
  licenseNumber String?     @map("license_number")
  expiryDate    DateTime?   @map("expiry_date") @db.Date
  documentUrl   String?     @map("document_url")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  distributor Distributor @relation(fields: [distributorId], references: [id])

  @@index([distributorId, expiryDate])
  @@map("licenses")
}

// ─── Contact Form (Lead Tracking) ────────────────────────────────────────────

model ContactSubmission {
  id            String   @id @default(uuid()) @map("submission_id")
  distributorId String?  @map("distributor_id") // NULL until they become a distributor
  name          String
  phone         String
  email         String?
  agency        String
  agencyName    String   @map("agency_name")
  monthlySale   String   @map("monthly_sale")
  status        String   @default("new") // new, contacted, converted, rejected
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  distributor Distributor? @relation(fields: [distributorId], references: [id])

  @@map("contact_submissions")
}

// ─── GST Reference Data ─────────────────────────────────────────────────────

model GstState {
  stateCode String @id @map("state_code")
  stateName String @map("state_name")

  @@map("gst_states")
}

model HsnCode {
  hsnCode     String @id @map("hsn_code")
  description String

  @@map("hsn_codes")
}

// ─── Provider Catalog (Super Admin Master) ──────────────────────────────────

model ProviderCatalogCylinderType {
  id           String   @id @default(uuid())
  providerCode String   @map("provider_code") // IOCL, HPCL, BPCL, GOGAS, SUPERGAS, TOTALGAS, OTHERS
  shortName    String   @map("short_name") // e.g. "19 KG"
  longName     String   @map("long_name") // e.g. "HPCL 19 KG Domestic Cylinder"
  weight       Float // capacity in KG
  hsnCode      String   @default("27111900") @map("hsn_code")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cylinderTypes CylinderType[]

  @@unique([providerCode, shortName])
  @@unique([providerCode, weight])
  @@map("provider_catalog_cylinder_types")
}

// ─── WI-4 — Stock Mismatch Records (Report Mismatch + Mismatch Log) ─────────
//
// One row per (mismatchType × cylinderType) line. All lines from a single
// "Report Mismatch" submission share a `reportId` UUID so the log can group
// them visually if needed; otherwise each row is independently filterable.

enum MismatchType {
  empties_short
  fulls_short
  both
}

enum AccountableParty {
  driver
  customer
}

enum MismatchResolutionAction {
  write_off
  settle_against_due
}

enum MismatchStatus {
  open
  resolved
}

model StockMismatchRecord {
  id               String                   @id @default(uuid()) @map("mismatch_id")
  reportId         String                   @map("report_id")
  distributorId    String                   @map("distributor_id")
  vehicleId        String                   @map("vehicle_id")
  vehicleNumber    String                   @map("vehicle_number")
  driverId         String?                  @map("driver_id")
  customerId       String?                  @map("customer_id")
  tripDate         DateTime                 @map("trip_date") @db.Date
  mismatchType     MismatchType             @map("mismatch_type")
  cylinderTypeId   String                   @map("cylinder_type_id")
  qtyUnaccounted   Int                      @map("qty_unaccounted")
  unitAmount       Decimal                  @map("unit_amount") @db.Decimal(12, 2)
  totalAmount      Decimal                  @map("total_amount") @db.Decimal(14, 2)
  accountableParty AccountableParty         @map("accountable_party")
  resolutionAction MismatchResolutionAction @map("resolution_action")
  resolutionNotes  String                   @map("resolution_notes")
  status           MismatchStatus           @default(open)
  resolvedAt       DateTime?                @map("resolved_at")
  resolvedBy       String?                  @map("resolved_by")
  createdBy        String                   @map("created_by")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  distributor  Distributor  @relation(fields: [distributorId], references: [id])
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])
  driver       Driver?      @relation(fields: [driverId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])

  @@index([distributorId, status])
  @@index([distributorId, vehicleId])
  @@index([distributorId, tripDate])
  @@index([reportId])
  @@map("stock_mismatch_records")
}

// ─── Email audit log ─────────────────────────────────────────────────────────
// Closes the auditability gap surfaced during Group B Part-2 investigation.
// Every outbound email (welcome, otp, contact_form, future templates) writes
// one row regardless of outcome so support can answer "did the email actually
// go out?" without grepping winston logs.
model EmailLog {
  id        String   @id @default(uuid()) @map("email_log_id")
  toEmail   String   @map("to_email")
  subject   String
  type      String   // welcome | password_reset_otp | contact_form | …
  status    String   // sent | failed | skipped
  errorText String?  @map("error_text")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([userId])
  @@map("email_logs")
}
