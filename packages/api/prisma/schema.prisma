  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@index([distributorId, cylinderTypeId, eventDate])
  @@index([distributorId, eventDate])
  @@index([referenceId, referenceType])
  @@map("inventory_events")
