// WI-PENDING-PAYMENTS: a self-reported payment claim from a driver or
// customer that has NOT yet been verified by office staff. Lives on the
// `payment_submissions` table — see model PaymentSubmission. NEVER
// stored on the PaymentTransaction row (that table's invariant is
// "every row is a cleared money event"; pending claims would leak
// into computeCustomerOverdue, Tally export, analytics KPIs, etc.).
enum AccountDeletionStatus {
  pending
  cancelled
  completed
}

enum PaymentSubmissionStatus {
  pending_verification
  verified
  rejected
}

// WI-PENDING-PAYMENTS: who submitted an unverified payment claim.
// `staff` covers any internal user (admin/finance/inventory) — if office
// staff are submitting via this flow at all, which is uncommon since
// they have direct POST /api/payments access.
enum PaymentSubmittedBy {
  staff
  driver
  customer
}

enum CreditNoteStatus {
  pending_cn   @map("pending")
  approved_cn  @map("approved")
  issued
  rejected_cn  @map("rejected")
  cancelled_cn @map("cancelled")
}

enum DebitNoteStatus {
  pending_dn   @map("pending")
  approved_dn  @map("approved")
  issued_dn    @map("issued")
  rejected_dn  @map("rejected")
