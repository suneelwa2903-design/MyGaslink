model PaymentCommitment {
  id                    String    @id @default(uuid()) @map("commitment_id")
  distributorId         String    @map("distributor_id")
  customerId            String    @map("customer_id")
  orderId               String?   @map("order_id")
  escalationLevel       Int       @map("escalation_level")
  overdueAmountSnapshot Decimal   @map("overdue_amount_snapshot") @db.Decimal(18, 4)
  promisedDate          DateTime? @map("promised_date") @db.Date
  promisedAmount        Decimal?  @map("promised_amount") @db.Decimal(18, 4)
  status                String    @default("open") // open | kept | broken | waived
  acknowledged          Boolean   @default(false)
  createdBy             String    @map("created_by")
  resolvedAt            DateTime? @map("resolved_at")
  resolvedBy            String?   @map("resolved_by")
