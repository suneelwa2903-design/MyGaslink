enum LedgerEntryType {
  invoice_entry @map("invoice")
  credit_note
  debit_note
  payment_entry @map("payment")
  adjustment
  // Q3 (2026-07-09) — stock-only ledger row for a customer empties
  // return. amountDelta always 0, invoiceId always null. Present so
  // the customer statement / ledger view can surface stock movement
  // that would otherwise be invisible outside the daily inventory
