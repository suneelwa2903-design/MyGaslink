// ─── GST Documents ───────────────────────────────────────────────────────────

model GstDocument {
  id                String     @id @default(uuid()) @map("gst_document_id")
  invoiceId         String?    @map("invoice_id")
  orderId           String?    @map("order_id")
  distributorId     String     @map("distributor_id")
  gstDocNo          String?    @map("gst_doc_no")
  docType           GstDocType @map("doc_type")
  irnStatus         IrnStatus  @default(not_attempted) @map("irn_status")
  ewbStatus         EwbStatus  @default(not_attempted) @map("ewb_status")
  irn               String?
  ackNo             String?    @map("ack_no")
  ackDate           DateTime?  @map("ack_date")
  signedQr          String?    @map("signed_qr")
  ewbNo             String?    @map("ewb_no")
  ewbDate           DateTime?  @map("ewb_date")
  ewbValidTill      DateTime?  @map("ewb_valid_till")
  requestPayload    Json?      @map("request_payload")
  responsePayload   Json?      @map("response_payload")
  errorCode         String?    @map("error_code")
  errorMessage      String?    @map("error_message")
  isLatest          Boolean    @default(true) @map("is_latest")
  cancelledAt       DateTime?  @map("cancelled_at")
  /// GROUP-7S: persisted cancellation context. NIC's CANCEL APIs accept
  /// CnlRsn (code '1'-'4': Duplicate / Data Entry Mistake / Order
  /// Cancelled / Others) + CnlRem (free text ≤100). The free text was
  /// previously sent to NIC but never stored — only buried in gst_api_logs.
  /// `cancelReason` keeps the operator's note queryable from the domain
  /// row; `cancelReasonCode` keeps NIC's structured code for GSTR audit.
  /// `cancelledByUserId` ties the action back to the user who clicked.
  cancelReason      String?    @map("cancel_reason")
  cancelReasonCode  String?    @map("cancel_reason_code")
  cancelledByUserId String?    @map("cancelled_by_user_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])
  cancelledBy User?    @relation("CancelledGstDocuments", fields: [cancelledByUserId], references: [id])

  @@index([invoiceId, isLatest])
  @@index([distributorId])
  @@index([irn])
  @@map("gst_documents")
}

