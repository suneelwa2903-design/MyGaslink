// ─── GasLink SaaS Billing ────────────────────────────────────────────────────

model BillingCycle {
  id                 String            @id @default(uuid()) @map("cycle_id")
  distributorId      String            @map("distributor_id")
  periodType         BillingPeriodType @map("period_type")
  periodStartDate    DateTime          @map("period_start_date") @db.Date
  periodEndDate      DateTime          @map("period_end_date") @db.Date
  billingStatus      BillingStatus     @default(pending_generation) @map("billing_status")
  billingTier        BillingTier       @map("billing_tier")
  totalAmountExclGst Decimal           @default(0) @map("total_amount_excl_gst") @db.Decimal(18, 4)
  totalGstAmount     Decimal           @default(0) @map("total_gst_amount") @db.Decimal(18, 4)
  totalAmountInclGst Decimal           @default(0) @map("total_amount_incl_gst") @db.Decimal(18, 4)
  invoiceId          String?           @map("invoice_id")
  dueDate            DateTime?         @map("due_date") @db.Date
  suspendDate        DateTime?         @map("suspend_date") @db.Date
  // Phase E (2026-06-12): Razorpay subscription payments. Populated when
  // the distributor pays via the Subscription tab "Pay Now" button.
  // razorpayOrderId is set at create-payment-order time; the rest land
  // when verify-payment or the webhook handler confirms capture.
  // Unit conventions: signature is the HMAC string verified server-side
  // (stored for audit / dispute investigation, never returned in any
  // API response); paid_at is wall-clock capture time, NOT due_date;
  // payment_method is Razorpay's classification (`upi` | `card` |
  // `netbanking` | `wallet` | `emi`).
  razorpayOrderId    String?           @map("razorpay_order_id")
  razorpayPaymentId  String?           @map("razorpay_payment_id")
  razorpaySignature  String?           @map("razorpay_signature")
  paidAt             DateTime?         @map("paid_at")
  paymentMethod      String?           @map("payment_method")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  distributor Distributor   @relation(fields: [distributorId], references: [id])
  items       BillingItem[]

  @@index([distributorId, periodStartDate])
  @@index([billingStatus])
  @@index([razorpayOrderId])
  @@map("gaslink_billing_cycles")
}

model BillingItem {
  id               String          @id @default(uuid()) @map("item_id")
  billingCycleId   String          @map("billing_cycle_id")
  itemType         BillingItemType @map("item_type")
  description      String
  hsnCode          String          @default("998314") @map("hsn_code")
  uom              String          @default("NOS")
  quantity         Int
  unitPriceExclGst Decimal         @map("unit_price_excl_gst") @db.Decimal(18, 4)
  gstRate          Float           @default(18) @map("gst_rate")
  discountAmount   Decimal         @default(0) @map("discount_amount") @db.Decimal(18, 4)
  lineTotalExclGst Decimal         @map("line_total_excl_gst") @db.Decimal(18, 4)
  lineGstAmount    Decimal         @map("line_gst_amount") @db.Decimal(18, 4)
  lineTotalInclGst Decimal         @map("line_total_incl_gst") @db.Decimal(18, 4)
  metadata         Json?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  billingCycle BillingCycle @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)

  @@map("gaslink_billing_items")
}

// ─── Pricing Configuration ──────────────────────────────────────────────────

model PricingTier {
  id                   String           @id @default(uuid()) @map("tier_id")
  plan                 SubscriptionPlan
  volumeMin            Int              @map("volume_min")
  volumeMax            Int?             @map("volume_max")
  monthlyPrice         Decimal          @map("monthly_price") @db.Decimal(18, 4)
  quarterlyDiscount    Float            @default(5) @map("quarterly_discount")
  halfYearlyDiscount   Float            @default(10) @map("half_yearly_discount")
  yearlyDiscount       Float            @default(15) @map("yearly_discount")
  adminSeats           Int              @default(1) @map("admin_seats")
