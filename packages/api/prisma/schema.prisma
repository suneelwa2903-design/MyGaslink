generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum UserRole {
  super_admin
  distributor_admin
  finance
  inventory
  driver
  customer
  // Feature A (2026-07-15): HQ user for a customer group (e.g. hotel
  // chain finance manager). Read-only across N customers in the same
  // CustomerGroup. Web-only in v1; mobile shows a "please use web"
  // fallback. Distinct role gate so we NEVER extend `requireRole('customer')`
  // — that gate protects Razorpay money endpoints on customerPortal.ts.
  customer_hq
  // Mini-Operator (2026-07-16): admin of a lightweight "mini_operator"
  // distributor. Same JWT/tenant model as distributor_admin (carries
  // distributorId), but restricted to a reduced UI + no GST/fleet/trip
  // surface. Enforced by explicit requireRole allow-list additions per
  // endpoint (positive-allow-list means missing = 403, fail-safe).
  mini_operator_admin
}

enum AccountType {
  // Standard full-featured distributor (default for every existing row).
  distributor
  // Mini-Operator (2026-07-16): lightweight distributor variant priced
  // at ₹1,999/month. No GST/IRN/EWB, no fleet, no drivers/trips. Adds
  // purchase-entry workflow + source-distributor list + free-text
  // driver name on orders. Invariant: accountType=mini_operator MUST
  // stay on gstMode=disabled — enforced in distributorService.
  mini_operator
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ProvisioningStatus {
  pending_approval
  approved
  provisioning
  active
  failed
}

enum DistributorStatus {
  active
  suspended
  inactive
}

enum GstMode {
  disabled
  sandbox
  live
}

enum CustomerStatus {
  active
  suspended
  inactive
}

enum OrderStatus {
  pending_driver_assignment
  pending_dispatch
  preflight_in_progress
  pending_delivery
  delivered
  modified_delivered
  cancelled
  returns_only
}

enum OrderType {
  delivery
  returns_only @map("returns_only")
}

// FLOAT-001 (2026-06-17): order provenance. `regular` covers every advance-booked
// order the system has shipped to date (default for migration backfill).
// `walk_in` is set ONLY by the driver mobile walk-in order path — used by the
// reconciliation float-unsold calculation to distinguish sold-from-float from
// pre-booked deliveries on the same trip.
enum OrderSource {
  regular
  walk_in @map("walk_in")
}

// Proof-of-collection Phase 1 (2026-07-15): per-order proof-of-delivery
// artifact type. `signature` = mobile-captured signature PNG uploaded to
// S3 + signing-party phone number. `photo` = camera-captured JPEG uploaded
// to S3 (Phase 2). `otp` = server-generated 6-digit code shown on the
// customer portal + typed by the driver (Phase 3). One proof per order,
// mutually exclusive types (upsert-by-orderId, latest wins).
enum ProofType {
  signature
  photo
  otp
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  overdue
  cancelled
}

enum IrnStatus {
  not_attempted
  pending
  success
  failed
  cancelled
  cancel_failed
}

enum EwbStatus {
  not_attempted
  pending
  active
  failed
  cancelled
}

enum GstDocType {
  INV
  CRN
  DBN
}

enum DriverStatus {
  active
  inactive
}

enum VehicleStatus {
  idle
  dispatched
  returned
  inactive
}

enum AssignmentStatus {
  dispatch_ready
  loaded_and_dispatched
  returned_inventory
  reconciled
  cancelled
}

enum AdjustmentStatus {
  pending
  approved
  rejected
}

enum CancelledStockStatus {
  pending_return    @map("pending")
  on_vehicle
  returned_to_depot
