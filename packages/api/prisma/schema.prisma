generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum UserRole {
  super_admin
  distributor_admin
  finance
  inventory
  driver
  customer
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ProvisioningStatus {
  pending_approval
  approved
  provisioning
  active
  failed
}

enum DistributorStatus {
  active
  suspended
  inactive
}

enum GstMode {
  disabled
  sandbox
  live
}

enum CustomerStatus {
  active
  suspended
  inactive
}

enum OrderStatus {
  pending_driver_assignment
  pending_dispatch
  preflight_in_progress
  pending_delivery
  delivered
  modified_delivered
  cancelled
  returns_only
}

enum OrderType {
  delivery
  returns_only @map("returns_only")
}

// FLOAT-001 (2026-06-17): order provenance. `regular` covers every advance-booked
// order the system has shipped to date (default for migration backfill).
// `walk_in` is set ONLY by the driver mobile walk-in order path — used by the
// reconciliation float-unsold calculation to distinguish sold-from-float from
// pre-booked deliveries on the same trip.
enum OrderSource {
  regular
  walk_in @map("walk_in")
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  overdue
  cancelled
}

enum IrnStatus {
  not_attempted
  pending
  success
  failed
  cancelled
  cancel_failed
}

enum EwbStatus {
  not_attempted
  pending
  active
  failed
  cancelled
}

enum GstDocType {
  INV
  CRN
  DBN
}

enum DriverStatus {
  active
  inactive
}

enum VehicleStatus {
  idle
  dispatched
  returned
  inactive
}

enum AssignmentStatus {
  dispatch_ready
  loaded_and_dispatched
  returned_inventory
  reconciled
  cancelled
}

enum AdjustmentStatus {
  pending
  approved
  rejected
}

enum CancelledStockStatus {
  pending_return    @map("pending")
  on_vehicle
  returned_to_depot
  reconciled
  written_off
}

enum InventoryEventType {
  incoming_fulls
  outgoing_empties
  delivery
  collection
  manual_adjustment
  cancellation
  cancellation_return
  initial_balance
  write_off
  returns_collection
  dispatch
  reconciliation_empties_return
}

enum ReplenishmentStatus {
  pending_replenishment @map("pending")
  in_transit
  completed
  rejected
}

enum PaymentMethod {
  cash
  cheque
  online
  upi
  bank_transfer
  credit
}

enum PaymentAllocationStatus {
  unallocated
  partially_allocated
  fully_allocated
}

enum CreditNoteStatus {
  pending_cn   @map("pending")
  approved_cn  @map("approved")
  issued
  rejected_cn  @map("rejected")
  cancelled_cn @map("cancelled")
}

enum DebitNoteStatus {
  pending_dn   @map("pending")
  approved_dn  @map("approved")
  issued_dn    @map("issued")
  rejected_dn  @map("rejected")
  cancelled_dn @map("cancelled")
}

enum BillingPeriodType {
  monthly
  quarterly
  half_yearly
  yearly
}

enum BillingStatus {
  pending_generation
  invoice_generated
  pending_payment
  paid_billing       @map("paid")
  overdue_billing    @map("overdue")
  suspended_billing  @map("suspended")
}

enum BillingTier {
  tier_1
  tier_2
  tier_3
  tier_4
}

enum BillingItemType {
  base_subscription
  driver_login
  other_login
  customer_portal
  gst_api_overage
  extra_seat
  custom_addon
  discount
  period_discount

  @@map("billing_item_type")
}

enum PendingActionModule {
  inventory
  invoice
  gst_compliance
  payment
  customer
  order
  driver
  billing
  collections
}

enum PendingActionStatus {
  open
  in_progress
  resolved
  failed
  skipped
}

enum PendingActionSeverity {
  low
  medium
  high
  critical
}

enum AccountabilityType {
  lost_cylinder
  damaged_cylinder
  missing_cylinder
  delivery_shortage
  customer_dispute
}

enum AccountabilityStatus {
  open_accountability  @map("open")
  investigating
  resolved_recovered
  resolved_written_off
  resolved_charged
  closed
}

enum LedgerEntryType {
  invoice_entry @map("invoice")
  credit_note
  debit_note
  payment_entry @map("payment")
  adjustment
}

enum ModificationType {
  update_info
  credit_limit_change
  stop_supply
  resume_supply
}

enum SubscriptionPlan {
  starter
  growth
  business
  enterprise
  // Phase 4a (2026-06-12): unlimited tier for distributors operating
  // above 50k cylinders/month. No seat caps; only a flat ₹24,999/mo
  // base price + per-call GST overage. Pricing structure rewrite in
  // seed.ts and tier-row updates handled separately — this enum value
  // had to land first so SubscriptionPlan? on Distributor can accept it.
  ultra

  @@map("subscription_plan")
}

enum SeatRequestStatus {
  pending_seat  @map("pending")
  approved_seat @map("approved")
  rejected_seat @map("rejected")

  @@map("seat_request_status")
}

enum LicenseType {
  peso
  gst_license           @map("gst")
  date_of_incorporation
  partnership_deed
  pan
  bank_account_details
  cancellation_cheque
  custom
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Organization & Users ────────────────────────────────────────────────────

model Distributor {
  id                      String            @id @default(uuid()) @map("distributor_id")
  businessName            String            @map("business_name")
  legalName               String            @map("legal_name")
  gstin                   String?
  address                 String?
  city                    String?
  state                   String?
  pincode                 String?
  phone                   String?
  email                   String?
  status                  DistributorStatus @default(active)
  gstMode                 GstMode           @default(disabled) @map("gst_mode")
  // Group A: gate that allows sandbox gstMode. Only true for dist-demo and
  // any future internal-only test tenants. Real distributors transition
  // disabled → live without ever passing through sandbox.
  isTestTenant            Boolean           @default(false) @map("is_test_tenant")
  // WI-108: 3-letter tenant code embedded in structured invoice/order
  // numbers (e.g. "SHD" → ISHD2526000123). Nullable: when unset the legacy
  // random INV-/ORD- format is used. Globally unique so codes never clash
  // across tenants (which keeps the per-tenant sequence globally unique too).
  docCode                 String?           @unique @map("doc_code")
  providerCodes           String[]          @default([]) @map("provider_codes")
  subscriptionPlan        SubscriptionPlan? @map("subscription_plan")
  billingTier             BillingTier?      @map("billing_tier")
  billingSuspended        Boolean           @default(false) @map("billing_suspended")
  gaslinkBillingEnabled   Boolean           @default(false) @map("gaslink_billing_enabled")
  gaslinkBillingStartDate DateTime?         @map("gaslink_billing_start_date") @db.Date
  /// Group 5 (2026-06-11): the date the distributor started operating on
  /// MyGasLink. Used to default `dateFrom` on reports (so legacy paper
  /// debt doesn't dominate Day-1 dashboards) and to backdate opening-
  /// balance invoices to goLiveDate - 1 day so they sit chronologically
  /// before the first live transaction.
  goLiveDate              DateTime?         @map("go_live_date") @db.Date
  latitude                Float?            @map("latitude")
  longitude               Float?            @map("longitude")

  // Godown / Warehouse address
  godownAddress   String? @map("godown_address")
  godownCity      String? @map("godown_city")
  godownState     String? @map("godown_state")
  godownPincode   String? @map("godown_pincode")
  godownLatitude  Float?  @map("godown_latitude")
  godownLongitude Float?  @map("godown_longitude")

  // Office address (if different from GST registered address)
  officeAddress String? @map("office_address")
  officeCity    String? @map("office_city")
  officeState   String? @map("office_state")
  officePincode String? @map("office_pincode")

  // Phase 3 (2026-06-11): bank + UPI payment details surfaced on invoice
  // and customer-ledger PDFs so end customers know where to pay. All
  // optional — PDFs render the "Payment Details" block only when
  // `bankAccountNumber` AND `ifscCode` are both present (UPI line is
  // appended only when `upiId` is also set). IFSC format enforced at
  // input boundary via shared regex; structure not enforced at the DB
  // level so import paths can recover gracefully from malformed legacy
  // data without a migration.
  bankName          String? @map("bank_name")
  bankAccountNumber String? @map("bank_account_number")
  bankBranchName    String? @map("bank_branch_name")
  ifscCode          String? @map("ifsc_code")
  upiId             String? @map("upi_id")

  // Phase F (2026-06-12): per-distributor Razorpay credentials for the
  // customer-portal "Pay Now" flow. razorpayEnabled is the
  // super-admin gate; the two secret fields are PLAINTEXT (accepted
  // risk — see CLAUDE.md "Accepted security risks", coordinated
  // encryption pass is the v1.1 plan covering this column plus
  // gst_credentials.client_secret + .password). Per-distributor model
  // is intentional: customer payments flow direct to the distributor's
  // Razorpay account, NOT through GasLink. Webhook secret is the
  // distributor's own (registered in their Razorpay dashboard).
  razorpayEnabled       Boolean @default(false) @map("razorpay_enabled")
  razorpayKeyId         String? @map("razorpay_key_id")
  razorpayKeySecret     String? @map("razorpay_key_secret")
  razorpayWebhookSecret String? @map("razorpay_webhook_secret")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  users                User[]
  customers            Customer[]
  orders               Order[]
  invoices             Invoice[]
  payments             PaymentTransaction[]
  drivers              Driver[]
  vehicles             Vehicle[]
  cylinderTypes        CylinderType[]
  cylinderPrices       CylinderPrice[]
  emptyCylinderPrices  EmptyCylinderPrice[]
  inventoryEvents      InventoryEvent[]
  inventorySummaries   InventorySummary[]
  settings             DistributorSetting[]
  billingCycles        BillingCycle[]
  pendingActions       PendingAction[]
  paymentCommitments   PaymentCommitment[]
  accountabilityLogs   AccountabilityLog[]
  stockMismatchRecords StockMismatchRecord[]
  auditLogs            AuditLog[]
  licenses             License[]
  gstCredentials       GstCredential[]
  contactSubmissions   ContactSubmission[]
  gstApiUsage          GstApiUsage[]
  seatRequests         SeatRequest[]
  invoiceCounters      InvoiceCounter[]
  tallySettings        TallySettings?
  // FLOAT-001 (2026-06-17): per-trip vehicle load manifests entered by admin
  // before dispatch. One row per (DVA, cylinderType, tripNumber).
  dvaLoadManifests     DVALoadManifest[]

  @@map("distributors")
}

model User {
  id                    String             @id @default(uuid()) @map("user_id")
  email                 String             @unique
  passwordHash          String             @map("password_hash")
  firstName             String             @map("first_name")
  lastName              String             @map("last_name")
  phone                 String?
  role                  UserRole
  status                UserStatus         @default(active)
  provisioningStatus    ProvisioningStatus @default(active) @map("provisioning_status")
  distributorId         String?            @map("distributor_id")
  customerId            String?            @map("customer_id")
  requiresPasswordReset Boolean            @default(true) @map("requires_password_reset")
  refreshToken          String?            @map("refresh_token")
  lastLoginAt           DateTime?          @map("last_login_at")
  loginAttempts         Int                @default(0) @map("login_attempts")
  lockedUntil           DateTime?          @map("locked_until")
  resetOtp              String?            @map("reset_otp")
  resetOtpExpiresAt     DateTime?          @map("reset_otp_expires_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  deletedAt             DateTime?          @map("deleted_at")

  // Relations
  distributor           Distributor?       @relation(fields: [distributorId], references: [id])
  customer              Customer?          @relation(fields: [customerId], references: [id])
  // Group B Part 3 — explicit Driver→User FK lives on the Driver side
  // (Driver.userId String? @unique). 1:0..1 — a driver can exist without
  // a login (orphan), and a user can exist without a driver record
  // (staff role). The reverse relation lets `prisma.user.findFirst({
  // include: { driverProfile: true } })` resolve a driver login to its
  // driver row without the phone-match dance in resolveDriverFromUser().
  driverProfile         Driver?            @relation("DriverUser")
  auditLogs             AuditLog[]
  driverAssignments     DriverAssignment[] @relation("AssignedBy")
  cancelledGstDocuments GstDocument[]      @relation("CancelledGstDocuments")
  loginHistory          LoginHistory[]
  // FLOAT-001 (2026-06-17): manifests this user confirmed (admin/inventory/finance).
  manifestsConfirmed    DVALoadManifest[]  @relation("ManifestConfirmedBy")

  @@index([email])
  @@index([distributorId])
  @@index([role, status])
  @@map("users")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id                         String         @id @default(uuid()) @map("customer_id")
  distributorId              String         @map("distributor_id")
  customerName               String         @map("customer_name")
  businessName               String?        @map("business_name")
  gstin                      String?
  customerType               String         @default("B2C") @map("customer_type") // B2B or B2C
  phone                      String
  email                      String?
  billingAddressLine1        String?        @map("billing_address_line1")
  billingAddressLine2        String?        @map("billing_address_line2")
  billingCity                String?        @map("billing_city")
  billingState               String?        @map("billing_state")
  billingPincode             String?        @map("billing_pincode")
  shippingAddressLine1       String?        @map("shipping_address_line1")
  shippingAddressLine2       String?        @map("shipping_address_line2")
  shippingCity               String?        @map("shipping_city")
  shippingState              String?        @map("shipping_state")
  shippingPincode            String?        @map("shipping_pincode")
  creditPeriodDays           Int            @default(30) @map("credit_period_days")
  // Optional per-customer inward transportation charge (₹ per delivered
  // cylinder, GST-inclusive — same basis as cylinder rates). 0 = no charge.
  transportChargePerCylinder Decimal        @default(0) @map("transport_charge_per_cylinder") @db.Decimal(18, 4)
  status                     CustomerStatus @default(active)
  stopSupply                 Boolean        @default(false) @map("stop_supply")
  preferredDriverId          String?        @map("preferred_driver_id")
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")
  deletedAt                  DateTime?      @map("deleted_at")

  // Relations
  distributor          Distributor                   @relation(fields: [distributorId], references: [id])
  users                User[]
  contacts             CustomerContact[]
  cylinderDiscounts    CustomerCylinderDiscount[]
  orders               Order[]
  invoices             Invoice[]
  payments             PaymentTransaction[]
  inventoryBalances    CustomerInventoryBalance[]
  ledgerEntries        CustomerLedgerEntry[]
  modificationRequests CustomerModificationRequest[]
  auditTrail           CustomerAuditTrail[]
  accountabilityLogs   AccountabilityLog[]
  paymentCommitments   PaymentCommitment[]
  stockMismatchRecords StockMismatchRecord[]

  @@index([distributorId, status])
  @@index([distributorId, customerName])
  @@index([gstin])
  @@map("customers")
}

model CustomerContact {
  id         String  @id @default(uuid()) @map("contact_id")
  customerId String  @map("customer_id")
  name       String
  phone      String
  email      String?
  isPrimary  Boolean @default(false) @map("is_primary")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_contacts")
}

model CustomerCylinderDiscount {
  id              String  @id @default(uuid()) @map("discount_id")
  customerId      String  @map("customer_id")
  cylinderTypeId  String  @map("cylinder_type_id")
  discountPerUnit Decimal @default(0) @map("discount_per_unit") @db.Decimal(18, 4)

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@unique([customerId, cylinderTypeId])
  @@map("customer_cylinder_discounts")
}

model CustomerInventoryBalance {
  id              String   @id @default(uuid()) @map("balance_id")
  customerId      String   @map("customer_id")
  cylinderTypeId  String   @map("cylinder_type_id")
  withCustomerQty Int      @default(0) @map("with_customer_qty")
  pendingReturns  Int      @default(0) @map("pending_returns")
  missingQty      Int      @default(0) @map("missing_qty")
  lastUpdated     DateTime @default(now()) @updatedAt @map("last_updated")

  customer     Customer     @relation(fields: [customerId], references: [id])
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@unique([customerId, cylinderTypeId])
  @@map("customer_inventory_balances")
}

model CustomerModificationRequest {
  id               String           @id @default(uuid()) @map("request_id")
  customerId       String           @map("customer_id")
  distributorId    String           @map("distributor_id")
  modificationType ModificationType @map("modification_type")
  requestedBy      String           @map("requested_by")
  reviewedBy       String?          @map("reviewed_by")
  status           AdjustmentStatus @default(pending)
  reason           String?
  changes          Json? // JSONB for field changes
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([distributorId, status])
  @@map("customer_modification_requests")
}

model CustomerAuditTrail {
  id            String   @id @default(uuid()) @map("trail_id")
  customerId    String   @map("customer_id")
  distributorId String   @map("distributor_id")
  performedBy   String   @map("performed_by")
  actionType    String   @map("action_type")
  fieldName     String?  @map("field_name")
  oldValue      Json?    @map("old_value")
  newValue      Json?    @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@map("customer_audit_trail")
}

model CustomerLedgerEntry {
  id            String          @id @default(uuid())
  distributorId String          @map("distributor_id")
  customerId    String          @map("customer_id")
  entryType     LedgerEntryType @map("entry_type")
  referenceId   String          @map("reference_id")
  invoiceId     String?         @map("invoice_id")
  amountDelta   Decimal         @map("amount_delta") @db.Decimal(18, 4)
  narration     String?
  entryDate     DateTime        @map("entry_date") @db.Date
  createdBy     String?         @map("created_by")
  createdAt     DateTime        @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([distributorId, customerId, entryDate])
  @@index([referenceId])
  @@map("customer_ledger_entries")
}

// ─── Products ────────────────────────────────────────────────────────────────

model CylinderType {
  id                String   @id @default(uuid()) @map("cylinder_type_id")
  distributorId     String   @map("distributor_id")
  typeName          String   @map("type_name")
  capacity          Float
  unit              String   @default("KG")
  hsnCode           String   @default("27111900") @map("hsn_code")
  // Optional pointer back to the provider catalog row this type was imported
  // from. Lets us trace tenant cylinder types back to the global IOCL/HPCL/etc.
  // catalog (nullable for legacy rows and for fully bespoke types).
  providerCatalogId String?  @map("provider_catalog_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  distributor          Distributor                  @relation(fields: [distributorId], references: [id])
  providerCatalog      ProviderCatalogCylinderType? @relation(fields: [providerCatalogId], references: [id])
  prices               CylinderPrice[]
  emptyPrices          EmptyCylinderPrice[]
  discounts            CustomerCylinderDiscount[]
  orderItems           OrderItem[]
  invoiceItems         InvoiceItem[]
  inventoryEvents      InventoryEvent[]
  inventorySummaries   InventorySummary[]
  customerBalances     CustomerInventoryBalance[]
  thresholds           CylinderThreshold[]
  cancelledStocks      CancelledStockEvent[]
  accountabilityLogs   AccountabilityLog[]
  stockMismatchRecords StockMismatchRecord[]
  // FLOAT-001 (2026-06-17): manifest rows recording per-trip loaded qty of this type.
  dvaLoadManifests     DVALoadManifest[]

  @@unique([distributorId, typeName])
  @@index([providerCatalogId])
  @@map("cylinder_types")
}

model CylinderPrice {
  id             String   @id @default(uuid()) @map("price_id")
  distributorId  String   @map("distributor_id")
  cylinderTypeId String   @map("cylinder_type_id")
  price          Decimal  @db.Decimal(18, 4)
  effectiveDate  DateTime @map("effective_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  distributor  Distributor  @relation(fields: [distributorId], references: [id])
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@index([distributorId, cylinderTypeId, effectiveDate(sort: Desc)])
  @@map("cylinder_prices")
}

model EmptyCylinderPrice {
  id                 String   @id @default(uuid()) @map("empty_price_id")
  distributorId      String   @map("distributor_id")
  cylinderTypeId     String   @map("cylinder_type_id")
  emptyCylinderPrice Decimal  @map("empty_cylinder_price") @db.Decimal(18, 4)
  createdAt          DateTime @default(now()) @map("created_at")

  distributor  Distributor  @relation(fields: [distributorId], references: [id])
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@unique([distributorId, cylinderTypeId])
  @@map("empty_cylinder_prices")
}

model CylinderThreshold {
  id             String  @id @default(uuid()) @map("threshold_id")
  distributorId  String  @map("distributor_id")
  cylinderTypeId String  @map("cylinder_type_id")
  warningLevel   Int     @map("warning_level")
  criticalLevel  Int     @map("critical_level")
  alertEnabled   Boolean @default(true) @map("alert_enabled")

  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@unique([distributorId, cylinderTypeId])
  @@map("cylinder_thresholds")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                    String      @id @default(uuid()) @map("order_id")
  orderNumber           String      @unique @map("order_number")
  distributorId         String      @map("distributor_id")
  customerId            String      @map("customer_id")
  driverId              String?     @map("driver_id")
  vehicleId             String?     @map("vehicle_id")
  orderDate             DateTime    @map("order_date") @db.Date
  deliveryDate          DateTime    @map("delivery_date") @db.Date
  status                OrderStatus @default(pending_driver_assignment)
  orderType             OrderType   @default(delivery) @map("order_type")
  // FLOAT-001 (2026-06-17): tagged by the driver mobile walk-in path. Reconciliation
  // sums delivered walk-ins as "sold from float" — depot debit happens at preflight
  // for ordered + manifest-float; whatever float remained at reconcile is credited
  // back via `cancellation_return` events. Default `regular` covers every legacy row.
  orderSource           OrderSource @default(regular) @map("order_source")
  totalAmount           Decimal     @default(0) @map("total_amount") @db.Decimal(18, 4)
  specialInstructions   String?     @map("special_instructions")
  deliveryLatitude      Float?      @map("delivery_latitude")
  deliveryLongitude     Float?      @map("delivery_longitude")
  deliveryNotes         String?     @map("delivery_notes")
  deliveredAt           DateTime?   @map("delivered_at")
  cancelledAt           DateTime?   @map("cancelled_at")
  cancellationReason    String?     @map("cancellation_reason")
  customerConfirmed     Boolean?    @map("customer_confirmed")
  customerConfirmedAt   DateTime?   @map("customer_confirmed_at")
  customerDisputeReason String?     @map("customer_dispute_reason")
  // WI-127: customer dispute lifecycle. customerDisputeReason holds the current
  // (or last) reason; the timestamps drive the customer-app state machine and
  // enforce a one-reopen-only rule.
  disputeRaisedAt       DateTime?   @map("dispute_raised_at")
  disputeResolvedAt     DateTime?   @map("dispute_resolved_at")
  disputeResolutionNote String?     @map("dispute_resolution_note")
  disputeReopenedAt     DateTime?   @map("dispute_reopened_at")
  disputeReopenReason   String?     @map("dispute_reopen_reason")
  // WI-065: per-order trip number. Stamped by preflightOne when the
  // order transitions to pending_delivery, mirrors DVA.tripNumber at
  // dispatch time. Replaces the fragile `updatedAt >= dva.updatedAt`
  // filter the trip-sheet PDF used to rely on. NULL for legacy orders
  // dispatched before this column existed — the trip-sheet service
  // falls back to the legacy filter for those.
  tripNumber            Int?        @map("trip_number")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  deletedAt             DateTime?   @map("deleted_at")

  // Relations
  distributor           Distributor           @relation(fields: [distributorId], references: [id])
  customer              Customer              @relation(fields: [customerId], references: [id])
  driver                Driver?               @relation(fields: [driverId], references: [id])
  vehicle               Vehicle?              @relation(fields: [vehicleId], references: [id])
  items                 OrderItem[]
  invoice               Invoice?
  statusLogs            OrderStatusLog[]
  driverAssignments     DriverAssignment[]
  cancelledStockEvents  CancelledStockEvent[]
  cancelledStockEventId String?               @unique @map("cancelled_stock_event_id")
  cancelledStockEvent   CancelledStockEvent?  @relation("TaggedOrder", fields: [cancelledStockEventId], references: [id])
  gstDocuments          GstDocument[]
  paymentCommitments    PaymentCommitment[]

  @@index([distributorId, status, deliveryDate])
  @@index([distributorId, customerId, createdAt(sort: Desc)])
  @@index([driverId, deliveryDate])
  @@map("orders")
}

model OrderItem {
  id                String  @id @default(uuid()) @map("order_item_id")
  orderId           String  @map("order_id")
  cylinderTypeId    String  @map("cylinder_type_id")
  quantity          Int
  deliveredQuantity Int?    @map("delivered_quantity")
  emptiesCollected  Int?    @map("empties_collected")
  unitPrice         Decimal @map("unit_price") @db.Decimal(18, 4)
  discountPerUnit   Decimal @default(0) @map("discount_per_unit") @db.Decimal(18, 4)
  totalPrice        Decimal @map("total_price") @db.Decimal(18, 4)

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id])

  @@map("order_items")
}

model OrderStatusLog {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  oldStatus String   @map("old_status")
  newStatus String   @map("new_status")
  changedBy String   @map("changed_by")
  notes     String?
  changedAt DateTime @default(now()) @map("changed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, changedAt])
  @@map("order_status_log")
}

// ─── Drivers & Vehicles ──────────────────────────────────────────────────────

model Driver {
  id                 String       @id @default(uuid()) @map("driver_id")
  distributorId      String       @map("distributor_id")
  driverName         String       @map("driver_name")
  phone              String
  licenseNumber      String?      @map("license_number")
  employmentType     String?      @map("employment_type")
  status             DriverStatus @default(active)
  availableToday     Boolean      @default(true) @map("available_today")
  preferredVehicleId String?      @map("preferred_vehicle_id")
  joiningDate        DateTime?    @map("joining_date") @db.Date
  deactivatedAt      DateTime?    @map("deactivated_at")
  deactivationNotes  String?      @map("deactivation_notes")
  // Group B Part 3 — explicit FK to the driver's app-login User row.
  // Nullable so a driver can exist without an immediate login (the Fleet
  // → Add Driver flow doesn't create a User; that happens later via the
  // role-first Add User modal which queries `unlinked=true` drivers).
  // @unique enforces 1:0..1 — one driver, at most one login. The legacy
  // phone-match join in resolveDriverFromUser() stays as a fallback for
  // any row that pre-dates this column being populated, but new flows
  // prefer this FK.
  userId             String?      @unique @map("user_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  deletedAt          DateTime?    @map("deleted_at")

  // Relations
  distributor          Distributor               @relation(fields: [distributorId], references: [id])
  user                 User?                     @relation("DriverUser", fields: [userId], references: [id])
  orders               Order[]
  vehicleAssignments   DriverVehicleAssignment[]
  driverAssignments    DriverAssignment[]
  accountabilityLogs   AccountabilityLog[]
  cancelledStockEvents CancelledStockEvent[]
  stockMismatchRecords StockMismatchRecord[]

  @@index([distributorId, status])
  @@map("drivers")
}

model Vehicle {
  id                String        @id @default(uuid()) @map("vehicle_id")
  distributorId     String        @map("distributor_id")
  vehicleNumber     String        @map("vehicle_number")
  vehicleType       String?       @map("vehicle_type")
  capacity          Int?
  status            VehicleStatus @default(idle)
  deactivatedAt     DateTime?     @map("deactivated_at")
  deactivationNotes String?       @map("deactivation_notes")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  // Relations
  distributor          Distributor               @relation(fields: [distributorId], references: [id])
  orders               Order[]
  vehicleAssignments   DriverVehicleAssignment[]
  vehicleInventory     VehicleInventory[]
  cancelledStockEvents CancelledStockEvent[]
  stockMismatchRecords StockMismatchRecord[]

  @@unique([distributorId, vehicleNumber])
  @@map("vehicles")
}

model DriverVehicleAssignment {
  id                      String           @id @default(uuid()) @map("assignment_id")
  driverId                String           @map("driver_id")
  vehicleId               String           @map("vehicle_id")
  distributorId           String           @map("distributor_id")
  assignmentDate          DateTime         @map("assignment_date") @db.Date
  tripNumber              Int              @default(1) @map("trip_number")
  status                  AssignmentStatus @default(dispatch_ready)
  isReconciled            Boolean          @default(false) @map("is_reconciled")
  isSubmitted             Boolean          @default(false) @map("is_submitted")
  // WI-038: consolidated EWB ("trip sheet") number persisted after a
  // successful gencewb call at the end of pre-dispatch preflight.
  tripSheetNo             String?          @map("trip_sheet_no")
  tripSheetGeneratedAt    DateTime?        @map("trip_sheet_generated_at")
  // WI-065: Add-to-Trip generates a SECOND consolidated EWB covering the
  // mid-trip batch (NIC has no "append" endpoint on gencewb — once
  // generated a CEWB is sealed; new orders need a fresh CEWB). The driver
  // carries both. Stays NULL when only one batch was dispatched.
  tripSheetNo2            String?          @map("trip_sheet_no_2")
  tripSheetNo2GeneratedAt DateTime?        @map("trip_sheet_no_2_generated_at")
  // WI-094: trip lifecycle timestamps. Set server-side only — dispatchedAt
  // on successful preflight, returnedAt on markVehicleReturned, reconciledAt
  // on reconcileVehicle. No client write path exposes these.
  dispatchedAt            DateTime?        @map("dispatched_at")
  returnedAt              DateTime?        @map("returned_at")
  reconciledAt            DateTime?        @map("reconciled_at")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  driver                Driver                          @relation(fields: [driverId], references: [id])
  vehicle               Vehicle                         @relation(fields: [vehicleId], references: [id])
  reconciliationEmpties ReconciliationEmptiesReturned[]
  // FLOAT-001 (2026-06-17): vehicle load manifest entries per trip.
  loadManifests         DVALoadManifest[]

  // WI-061: prevent duplicate DVA rows for the same driver+date+trip.
  // The dev DB accumulated 4 rows for one driver/date because nothing
  // enforced uniqueness; trip-sheet UX picks whichever row the user
  // clicks, producing inconsistent output. preflightDispatch reuses
  // the same DVA row across trips (increments tripNumber in place),
  // so the natural key is (driverId, assignmentDate, tripNumber).
  @@unique([driverId, assignmentDate, tripNumber])
  @@index([distributorId, assignmentDate])
  @@index([driverId, assignmentDate])
  @@map("driver_vehicle_assignments")
}

// FLOAT-001 (2026-06-17): admin-confirmed load manifest. One row per
// (DVA, cylinderType, tripNumber). Lets the system represent "vehicle V left the
// depot carrying X cylinders" — separate from order-sum — so depot stock debits
// correctly even when some cylinders are float for walk-in customers.
//
// `tripNumber` lives on the row directly (not derived from `dva.tripNumber` at
// read time) because a DVA's tripNumber rolls forward on each new dispatch; we
// must preserve per-trip audit history. The composite key
// `[dvaId, cylinderTypeId, tripNumber]` permits trip-2 manifest to coexist with
// trip-1 manifest on the same DVA row.
//
// `totalLoaded` is the admin's declared physical count.
// `orderedQty` is a snapshot of Σ OrderItem.quantity for pending_dispatch orders
//   on (driverId, assignmentDate) at manifest-write time. Stored (not derived)
//   so reconciliation reads the value as-at-confirm without re-querying orders.
// `floatQty = totalLoaded - orderedQty`, stored for audit + cheap reads.
model DVALoadManifest {
  id             String   @id @default(uuid()) @map("manifest_id")
  distributorId  String   @map("distributor_id")
  dvaId          String   @map("dva_id")
  cylinderTypeId String   @map("cylinder_type_id")
  tripNumber     Int      @map("trip_number")
  totalLoaded    Int      @map("total_loaded")
  orderedQty     Int      @map("ordered_qty")
  floatQty       Int      @map("float_qty")
  confirmedBy    String   @map("confirmed_by")
  confirmedAt    DateTime @default(now()) @map("confirmed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  distributor     Distributor             @relation(fields: [distributorId], references: [id])
  dva             DriverVehicleAssignment @relation(fields: [dvaId], references: [id])
  cylinderType    CylinderType            @relation(fields: [cylinderTypeId], references: [id])
  confirmedByUser User                    @relation("ManifestConfirmedBy", fields: [confirmedBy], references: [id])

  @@unique([dvaId, cylinderTypeId, tripNumber])
  @@index([distributorId])
  @@index([dvaId, tripNumber])
  @@map("dva_load_manifests")
}

// Supervisor's physically-verified per-type empties count captured at trip-end
// reconciliation. Separate from delivery-time `collection` events so a gap
// (collected-per-app vs physically-returned) can be measured. One row per
// cylinder type per reconciled trip (DVA).
model ReconciliationEmptiesReturned {
  id             String   @id @default(uuid())
  distributorId  String   @map("distributor_id")
  dvaId          String   @map("dva_id")
  cylinderTypeId String   @map("cylinder_type_id")
  quantity       Int
  createdAt      DateTime @default(now()) @map("created_at")

  dva DriverVehicleAssignment @relation(fields: [dvaId], references: [id])

  @@index([distributorId])
  @@index([dvaId])
  @@map("reconciliation_empties_returned")
}

model DriverAssignment {
  id         String   @id @default(uuid()) @map("assignment_id")
  orderId    String   @map("order_id")
  driverId   String   @map("driver_id")
  assignedBy String   @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")
  status     String   @default("active")
  notes      String?

  order          Order  @relation(fields: [orderId], references: [id])
  driver         Driver @relation(fields: [driverId], references: [id])
  assignedByUser User   @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@index([orderId])
  @@map("driver_assignments")
}

model VehicleInventory {
  id             String   @id @default(uuid())
  vehicleId      String   @map("vehicle_id")
  cylinderTypeId String   @map("cylinder_type_id")
  fullQuantity   Int      @default(0) @map("full_quantity")
  emptyQuantity  Int      @default(0) @map("empty_quantity")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@unique([vehicleId, cylinderTypeId])
  @@map("vehicle_inventory")
}

// ─── Invoices ────────────────────────────────────────────────────────────────

/// WI-108: per-(distributor, docType, financialYear) sequence counter for
/// structured invoice/order numbering. The unique key serialises concurrent
/// allocations on a single row (atomic `{ increment: 1 }`); a new financial
/// year inserts a fresh row so the sequence resets automatically every April.
/// docType is a single char: I=invoice R=revision C=credit D=debit O=order.
model InvoiceCounter {
  id            String   @id @default(cuid()) @map("counter_id")
  distributorId String   @map("distributor_id")
  type          String
  financialYear String   @map("financial_year")
  lastSequence  Int      @default(0) @map("last_sequence")
  updatedAt     DateTime @updatedAt @map("updated_at")

  distributor Distributor @relation(fields: [distributorId], references: [id])

  @@unique([distributorId, type, financialYear])
  @@index([distributorId])
  @@map("invoice_counters")
}

model Invoice {
  id                    String        @id @default(uuid()) @map("invoice_id")
  invoiceNumber         String        @unique @map("invoice_number")
  distributorId         String        @map("distributor_id")
  customerId            String?       @map("customer_id")
  orderId               String?       @unique @map("order_id")
  issueDate             DateTime      @map("issue_date") @db.Date
  dueDate               DateTime      @map("due_date") @db.Date
  totalAmount           Decimal       @default(0) @map("total_amount") @db.Decimal(18, 4)
  amountPaid            Decimal       @default(0) @map("amount_paid") @db.Decimal(18, 4)
  outstandingAmount     Decimal       @default(0) @map("outstanding_amount") @db.Decimal(18, 4)
  status                InvoiceStatus @default(draft)
  irnStatus             IrnStatus     @default(not_attempted) @map("irn_status")
  ewbStatus             EwbStatus     @default(not_attempted) @map("ewb_status")
  irn                   String?
  ackNo                 String?       @map("ack_no")
  ackDate               DateTime?     @map("ack_date")
  cgstValue             Decimal       @default(0) @map("cgst_value") @db.Decimal(18, 4)
  sgstValue             Decimal       @default(0) @map("sgst_value") @db.Decimal(18, 4)
  igstValue             Decimal       @default(0) @map("igst_value") @db.Decimal(18, 4)
  // Phase 5 (2026-06-12): GSTR-1 export columns. Nullable on historical
  // rows; populated at write time for every new invoice via
  // invoiceService.createInvoiceFromOrder. A one-shot backfill script
  // (scripts/gstr1-backfill.ts, dry-run by default) computes these for
  // pre-Phase-5 rows where possible.
  //   - taxableValue: assessable amount (totalAmount / (1 + gstRate/100))
  //   - placeOfSupplyCode: 2-digit state code (Table 4 / 5 / 7 driver)
  //   - reverseCharge: GSTR-1 Table 4 — LPG is NOT RCM so default false
  //   - customerGstinSnapshot: snapshot at issue time so a customer-side
  //     GSTIN edit doesn't drift the historical GSTR-1 record
  taxableValue          Decimal?      @map("taxable_value") @db.Decimal(18, 4)
  placeOfSupplyCode     String?       @map("place_of_supply_code")
  reverseCharge         Boolean       @default(false) @map("reverse_charge")
  customerGstinSnapshot String?       @map("customer_gstin_snapshot")
  isGaslinkBilling      Boolean       @default(false) @map("is_gaslink_billing")
  isOpeningBalance      Boolean       @default(false) @map("is_opening_balance")
  // WI-037: set when a post-delivery reissue (cancel + regenerate IRN/EWB
  // because delivered qty ≠ ordered qty) has been applied. Used by the
  // reissue audit + UI badges.
  revisedPostDeliveryAt DateTime?     @map("revised_post_delivery_at")
  notes                 String?
  issuedBy              String?       @map("issued_by")
  closedAt              DateTime?     @map("closed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  // Relations
  distributor        Distributor         @relation(fields: [distributorId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  items              InvoiceItem[]
  paymentAllocations PaymentAllocation[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]
  gstDocuments       GstDocument[]
  revisions          InvoiceRevision[]

  @@index([distributorId, status, dueDate])
  @@index([distributorId, customerId, createdAt(sort: Desc)])
  @@index([irnStatus])
  @@map("invoices")
}

/// WI-037: append-only audit row capturing every post-IRN reissue of an
/// invoice. Created whenever cancel + regenerate IRN/EWB runs because
/// delivery quantities diverged from what was preflighted. The JSON
/// snapshots are deliberately denormalised so the row stays meaningful
/// even if the invoice is later mutated again.
model InvoiceRevision {
  id             String   @id @default(uuid()) @map("revision_id")
  invoiceId      String   @map("invoice_id")
  distributorId  String   @map("distributor_id")
  revisionNumber Int      @map("revision_number")
  reason         String
  originalTotal  Decimal  @map("original_total") @db.Decimal(18, 4)
  revisedTotal   Decimal  @map("revised_total") @db.Decimal(18, 4)
  originalItems  Json     @map("original_items")
  revisedItems   Json     @map("revised_items")
  revisedBy      String?  @map("revised_by")
  revisedAt      DateTime @default(now()) @map("revised_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([distributorId])
  @@map("invoice_revisions")
}

model InvoiceItem {
  id              String  @id @default(uuid()) @map("invoice_item_id")
  invoiceId       String  @map("invoice_id")
  cylinderTypeId  String? @map("cylinder_type_id")
  description     String
  hsnCode         String  @default("27111900") @map("hsn_code")
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(18, 4)
  discountPerUnit Decimal @default(0) @map("discount_per_unit") @db.Decimal(18, 4)
  gstRate         Float   @default(18) @map("gst_rate")
  totalPrice      Decimal @map("total_price") @db.Decimal(18, 4)
  // Phase 5 (2026-06-12): GSTR-1 HSN summary (Table 12) inputs. Nullable
  // on historical rows; populated at write time on every new item via
  // invoiceService. taxableValue is the per-line assessable amount;
  // `uom` defaults to 'NOS' (numbers) because LPG is invoiced per cylinder
  // — the CylinderType.unit field defaults to 'KG' (cylinder capacity)
  // which is NOT the correct GSTR-1 UQC for the LINE, just for the
  // product spec.
  taxableValue    Decimal? @map("taxable_value") @db.Decimal(18, 4)
  uom             String  @default("NOS") @map("uom")

  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  cylinderType CylinderType? @relation(fields: [cylinderTypeId], references: [id])

  @@map("invoice_items")
}

model CreditNote {
  id               String           @id @default(uuid()) @map("credit_note_id")
  invoiceId        String           @map("invoice_id")
  creditNoteNumber String?          @unique @map("credit_note_number")
  totalAmount      Decimal          @map("total_amount") @db.Decimal(18, 4)
  reason           String
  // WI-055: free-text customer-visible explanation. Optional, separate
  // from `reason` which stays a single-line summary used in audit logs.
  note             String?
  status           CreditNoteStatus @default(pending_cn)
  issueDate        DateTime?        @map("issue_date") @db.Date
  // Phase 5 (2026-06-12): GSTR-1 Table 9B (Credit / Debit Notes) inputs.
  // Pre-Phase-5 CreditNotes carried only totalAmount; the tax splits and
  // reason classification had to be re-derived at export time from the
  // original invoice + free-text reason, which was lossy. Nullable on
  // historical rows; populated at write time on every new credit note.
  //   - taxableValue: assessable amount on the credit
  //   - cgst/sgst/igst: tax components (intra-state uses cgst+sgst; inter
  //     uses igst). Aligned with the same precision as Invoice columns.
  //   - reasonCode: NIC GSTR-1 code — 'R'=Return, 'D'=Deficiency,
  //     'C'=Correction. Free-text reason stays as the human-readable line.
  taxableValue     Decimal?         @map("taxable_value") @db.Decimal(18, 4)
  cgstValue        Decimal?         @map("cgst_value") @db.Decimal(18, 4)
  sgstValue        Decimal?         @map("sgst_value") @db.Decimal(18, 4)
  igstValue        Decimal?         @map("igst_value") @db.Decimal(18, 4)
  reasonCode       String?          @map("reason_code")
  issuedBy         String?          @map("issued_by")
  approvedBy       String?          @map("approved_by")
  approvedAt       DateTime?        @map("approved_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("credit_notes")
}

model DebitNote {
  id              String          @id @default(uuid()) @map("debit_note_id")
  invoiceId       String          @map("invoice_id")
  debitNoteNumber String?         @unique @map("debit_note_number")
  totalAmount     Decimal         @map("total_amount") @db.Decimal(18, 4)
  reason          String
  // WI-055: same as CreditNote.note above.
  note            String?
  status          DebitNoteStatus @default(pending_dn)
  issueDate       DateTime?       @map("issue_date") @db.Date
  issuedBy        String?         @map("issued_by")
  approvedBy      String?         @map("approved_by")
  approvedAt      DateTime?       @map("approved_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("debit_notes")
}

// ─── Payments ────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id               String                  @id @default(uuid()) @map("payment_id")
  distributorId    String                  @map("distributor_id")
  customerId       String                  @map("customer_id")
  amount           Decimal                 @db.Decimal(18, 4)
  paymentMethod    PaymentMethod           @map("payment_method")
  referenceNumber  String?                 @map("reference_number")
  transactionDate  DateTime                @map("transaction_date") @db.Date
  allocationStatus PaymentAllocationStatus @default(unallocated) @map("allocation_status")
  receivedBy       String?                 @map("received_by")
  notes            String?
  // Phase F (2026-06-12): forensic Razorpay fields when this payment
  // came from the customer-portal Pay Now flow. NULL on manually
  // recorded payments. razorpaySignature stored for audit / dispute
  // investigation, NEVER returned in any API response.
  razorpayOrderId   String?                @map("razorpay_order_id")
  razorpayPaymentId String?                @map("razorpay_payment_id")
  razorpaySignature String?                @map("razorpay_signature")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  deletedAt        DateTime?               @map("deleted_at")

  distributor Distributor         @relation(fields: [distributorId], references: [id])
  customer    Customer            @relation(fields: [customerId], references: [id])
  allocations PaymentAllocation[]

  @@index([distributorId, customerId, createdAt(sort: Desc)])
  @@index([distributorId, transactionDate])
  @@index([razorpayOrderId])
  @@map("payment_transactions")
}

model PaymentAllocation {
  id              String   @id @default(uuid()) @map("allocation_id")
  paymentId       String   @map("payment_id")
  invoiceId       String   @map("invoice_id")
  allocatedAmount Decimal  @map("allocated_amount") @db.Decimal(18, 4)
  createdAt       DateTime @default(now()) @map("created_at")

  payment PaymentTransaction @relation(fields: [paymentId], references: [id])
  invoice Invoice            @relation(fields: [invoiceId], references: [id])

  @@map("payment_allocations")
}

// ─── Inventory (Event-Sourced) ───────────────────────────────────────────────

model InventoryEvent {
  id               String             @id @default(uuid()) @map("event_id")
  distributorId    String             @map("distributor_id")
  cylinderTypeId   String             @map("cylinder_type_id")
  eventType        InventoryEventType @map("event_type")
  fullsChange      Int                @default(0) @map("fulls_change")
  emptiesChange    Int                @default(0) @map("empties_change")
  eventDate        DateTime           @map("event_date") @db.Date
  referenceId      String?            @map("reference_id")
  referenceType    String?            @map("reference_type")
  documentType     String?            @map("document_type")
  documentNumber   String?            @map("document_number")
  documentDate     DateTime?          @map("document_date") @db.Date
  vehicleNumber    String?            @map("vehicle_number")
  driverName       String?            @map("driver_name")
  // WI-1.4 — additional metadata captured by the Incoming Fulls /
  // Outgoing Empties modals. All nullable so existing rows + non-using
  // event types stay untouched.
  amount           Decimal?           @map("amount") @db.Decimal(12, 2)
  condition        String?            @map("condition") // 'good' | 'defective' (outgoing-empties only)
  authorizationRef String?            @map("authorization_ref")
  notes            String?
  createdBy        String             @map("created_by")
  createdAt        DateTime           @default(now()) @map("created_at")

