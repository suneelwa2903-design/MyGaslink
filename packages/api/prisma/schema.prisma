  extraSeatPriceAdmin  Decimal          @default(999) @map("extra_seat_price_admin") @db.Decimal(18, 4)
  extraSeatPriceDriver Decimal          @default(299) @map("extra_seat_price_driver") @db.Decimal(18, 4)
  // Phase 4a (2026-06-12): per-role addon pricing. Old schema priced every
  // overage seat at extraSeatPriceAdmin regardless of role — finance and
  // inventory teams got over-billed when seatRequestService routed through
  // that single column (Phase 4b fixes the service, this adds the columns).
  extraSeatPriceFinance   Decimal       @default(499) @map("extra_seat_price_finance") @db.Decimal(18, 4)
  extraSeatPriceInventory Decimal       @default(499) @map("extra_seat_price_inventory") @db.Decimal(18, 4)
  extraSeatPriceCustomer  Decimal       @default(249) @map("extra_seat_price_customer") @db.Decimal(18, 4)
  // Phase 4a: how many customer-portal logins each plan includes for free
