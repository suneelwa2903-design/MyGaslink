# ═══════════════════════════════════════════════════════════════════════════════
# packages/mobile — Local override (gitignored)
#
# Copy this to `.env.local` and fill in your laptop's LAN IP. Expo loads
# .env.local in priority over .env, so this file is the right place for
# per-developer values you don't want to commit.
#
#   cp .env.local.example .env.local
#   # then edit .env.local and replace 192.168.1.5 with your actual IP
#
# Find your LAN IP:
#   Windows:   ipconfig         → IPv4 Address under your Wi-Fi adapter
#   macOS:     ifconfig | grep inet
#   Linux:     hostname -I
#
# Then start the API bound to 0.0.0.0 (it does this automatically in dev) and
# run `pnpm --filter @gaslink/mobile start` and scan the QR with Expo Go.
# ═══════════════════════════════════════════════════════════════════════════════

# Replace 192.168.1.5 with YOUR LAN IP — do NOT use localhost on a phone
EXPO_PUBLIC_API_URL=http://192.168.1.5:5000/api

# Emulator alternatives (uncomment one if not using a physical device):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api    # Android emulator
# EXPO_PUBLIC_API_URL=http://localhost:5000/api   # iOS simulator / Expo Web

# Sentry — leave blank in local dev unless you specifically want crash reports
EXPO_PUBLIC_SENTRY_DSN=
