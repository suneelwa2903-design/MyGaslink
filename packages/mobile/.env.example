# ═══════════════════════════════════════════════════════════════════════════════
# packages/mobile — Expo env vars
#
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the native bundle.
# Copy to .env.local for local dev (gitignored).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── API URL ──────────────────────────────────────────────────────────────────
# REQUIRED. Change to your laptop's LAN IP for phone testing on Expo Go.
#   Windows:   ipconfig          → "IPv4 Address" under your Wi-Fi adapter
#   macOS:     ifconfig | grep inet
#   Linux:     hostname -I
# Example:     EXPO_PUBLIC_API_URL=http://192.168.1.5:5000/api
#
# Emulator-only shortcuts (no LAN IP needed):
#   Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api
#   iOS simulator:    EXPO_PUBLIC_API_URL=http://localhost:5000/api
#   Web:              EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:5000/api

# ─── Sentry (optional in dev) ─────────────────────────────────────────────────
# Wired into preview/production builds via eas.json env. Leave blank for dev
# unless you want to send local crash reports to Sentry.
EXPO_PUBLIC_SENTRY_DSN=
