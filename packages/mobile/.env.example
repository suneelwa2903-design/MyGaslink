# ═══════════════════════════════════════════════════════════════════════════════
# packages/mobile — Expo env vars
#
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the native bundle.
# Copy to .env.local for local dev (gitignored).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── API ───────────────────────────────────────────────────────────────────────
# Use your machine's LAN IP when testing on a real device (Expo Go).
# Default 'http://localhost:5000/api' only works on web/iOS simulator.
EXPO_PUBLIC_API_URL="http://localhost:5000/api"
