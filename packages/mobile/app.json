{
  "expo": {
    "name": "MyGasLink",
    "slug": "mygaslink",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#338dff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mygaslink.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location for delivery tracking",
        "NSCameraUsageDescription": "MyGasLink needs camera access to capture proof of delivery photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "mailto",
          "tel"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#338dff"
      },
      "package": "com.mygaslink.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mygaslink.com"
            },
            {
              "scheme": "https",
              "host": "www.mygaslink.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": false,
          "locationAlwaysPermission": false,
          "locationWhenInUsePermission": "Allow MyGasLink to use your location for delivery tracking.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "MyGasLink needs camera access to capture proof of delivery photos."
        }
      ],
      "./plugins/withResizeableActivity",
      "./plugins/withoutRecordAudio",
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "visibility": "sticky-immersive"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "scheme": "mygaslink",
    "extra": {
      "eas": {
        "projectId": "43a84457-0603-4883-8247-c351f159f575"
      },
      "router": {
        "origin": false
      }
    },
    "updates": {
      "url": "https://u.expo.dev/",
      "fallbackToCacheTimeout": 5000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "mygaslinks-organization"
  }
}
