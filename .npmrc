auto-install-peers=true
strict-peer-dependencies=false

# Hoist the entire workspace's node_modules into a flat layout.
#
# Why: react-native-reanimated 4.x (transitive peer of expo-router) runs a
# Node `require.resolve('react-native')` inside its android/build.gradle at
# evaluation time. Under pnpm's default symlinked layout the nested
# .pnpm/<hash>/node_modules paths can't see the project's top-level
# react-native, so the Gradle exec fails with
#   Process 'command 'node'' finished with non-zero exit value 1
# and EAS builds crash before assembleDebug. The same root cause hits any
# package whose Gradle script does node require.resolve at evaluation time.
#
# MUST be at the workspace root — pnpm reads .npmrc from the install cwd,
# which is the workspace root both locally and on EAS. A node-linker entry
# in packages/mobile/.npmrc is only honoured when commands run from inside
# that folder; EAS doesn't.
#
# Tradeoffs: api/web/shared install into a flat tree instead of pnpm's
# symlinked isolation; phantom-dependency imports become possible. The
# 78-file / 857-test API suite still passes after the relayout — the
# gradle-compat win is worth it for a project that ships a native mobile
# app.
#
# Reference: https://docs.expo.dev/guides/monorepos/ ("Using pnpm" section).
node-linker=hoisted
